{
  "name": "hideaway57",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "prisma generate && next build",
    "build:render": "npm run installers:build && npm run carousel:build && prisma generate && prisma migrate deploy && tsx prisma/seed.ts && next build",
    "start": "next start -p ${PORT:-3000}",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "installers:build": "tsx scripts/build-installers.ts",
    "covers:extract": "tsx scripts/extract-game-covers.ts",
    "covers:figma": "tsx scripts/export-figma-covers.ts",
    "cards:figma": "tsx scripts/export-figma-cards.ts",
    "carousel:build": "tsx scripts/build-carousel-images.ts",
    "logo:figma": "tsx scripts/export-figma-logo.ts",
    "deploy:render:docker": "bash scripts/deploy-render-docker.sh",
    "db:setup": "npm run installers:build && prisma migrate dev && prisma db seed"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "jszip": "^3.10.1",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5",
    "stripe": "^22.1.1",
    "tsx": "^4.22.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
